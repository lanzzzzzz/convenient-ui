{
  "name": "schema-ui",
  "version": "1.0.0",
  "private": true,
  "description": "Enterprise Admin Toolkit",
  "packageManager": "pnpm@10.29.2",
  "scripts": {
    "build": "turbo run build --filter=\"@convenient-ui/*\"",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "changeset": "changeset",
    "version:update": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "turbo": "^2.8.3",
    "typescript": "^5.9.3",
    "vitepress": "^1.6.4",
    "vue": "^3.5.30"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@convenient-ui/vue-ui": "workspace:*",
    "element-plus": "^2.13.6",
    "eslint": "^8.57.1",
    "postcss-html": "^1.8.1",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.8.1",
    "stylelint": "^16.26.1",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard-scss": "^13.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}