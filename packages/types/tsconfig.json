{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",         // 👈 核心修改：从 CommonJS 改为 ESNext
    "moduleResolution": "node", // 👈 补充：让 TS 更好地解析 Node 模块路径
    "declaration": true,
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src"]
}